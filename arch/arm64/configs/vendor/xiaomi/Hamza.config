# --- [ SECTION 1: SYSTEMD CORE SUPPORT ] ---
# Necessary for Ubuntu, Debian, and Fedora to boot
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FHANDLE=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y
CONFIG_INOTIFY_USER=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_AUTOFS4_FS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_SECCOMP=y
CONFIG_CHECKPOINT_RESTORE=y

# --- [ SECTION 2: VIRTUALIZATION & KVM ] ---
# Enable KVM for ARM64 (Run Windows/Linux VMs on Miatoll)
CONFIG_ARM_VIRT_EXT=y
CONFIG_KVM=y
CONFIG_KVM_ARM_HOST=y
CONFIG_VIRTUALIZATION=y
CONFIG_VHOST_NET=y
CONFIG_IP_NF_TARGET_MASQUERADE=y

# --- [ SECTION 3: NATIVE GRAPHICS & DRM ] ---
# Required for Wayland (Phosh, Plasma Mobile) and X11
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_PANEL_ORIENTATION_QUIRKS=y
CONFIG_FB=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_LCD_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_DMA_SHARED_BUFFER=y

# --- [ SECTION 4: DOCKER & CONTAINER SUPPORT ] ---
# Full containerization support
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_USER_NS=y
CONFIG_BRIDGE=y
CONFIG_VETH=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y

# --- [ SECTION 5: EFI STUB & BOOTING ] ---
# Required for booting via GRUB or rEFInd on Miatoll
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_PARAMS_FROM_FDT=y
CONFIG_EFI_RUNTIME_WRAPPERS=y

# --- [ SECTION 6: LINUX CLEANUP & PERMISSIONS ] ---
# Fixes "No Internet" issues in Native Linux (Android security removal)
# CONFIG_ANDROID_PARANOID_NETWORK is NOT SET
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_BINFMT_MISC=y
# CONFIG_SECURITY_SELINUX is NOT SET
